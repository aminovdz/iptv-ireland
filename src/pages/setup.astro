---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppPopup from '../components/WhatsAppPopup.astro';
import WhatsPopup from '../components/WhatsPopup.astro';

const title = "Setup Guide | IPTV Ireland — Install on Any Device";
const description = "Step-by-step setup guides for IPTV Ireland on Smart TV, Firestick, Android, Apple, Windows and more. Get streaming in minutes.";

const devices = [
  { id: 'smarttv', name: 'Smart TV', brands: 'Samsung, LG, Sony', steps: ['Open your TV app store (LG Content Store, Samsung Smart Hub, etc.)', 'Search for IPTV Smarters Pro or SS IPTV', 'Download and install the app', 'Open the app and enter your login credentials', 'Wait for the channel list to load and start watching'] },
  { id: 'firestick', name: 'Fire TV Stick', brands: 'Amazon Fire TV, Fire Stick 4K', steps: ['Go to Settings then My Fire TV then Developer Options', 'Enable Apps from Unknown Sources', 'Search for Downloader in the Amazon App Store and install it', 'Open Downloader and enter the URL for your IPTV app', 'Install the app then enter your login credentials'] },
  { id: 'android', name: 'Android', brands: 'Android TV, Phone, Tablet', steps: ['Open Google Play Store on your device', 'Search for a trusted IPTV player like IPTV Smarters Pro', 'Install the app and open it', 'Enter your login credentials or M3U playlist URL', 'Load your channels and start streaming'] },
  { id: 'apple', name: 'Apple', brands: 'iPhone, iPad, Apple TV', steps: ['Open the App Store on your Apple device', 'Search for IPTV Smarters Pro or GSE Smart IPTV', 'Download and install the app', 'Open the app and select Add Playlist', 'Enter your M3U URL or Xtream Codes API credentials'] },
  { id: 'windows', name: 'Windows', brands: 'Windows 10, Windows 11', steps: ['Visit iptv-irish.ie and log into your account', 'Download the recommended Windows IPTV player or use VLC Media Player', 'Open VLC and go to Media then Open Network Stream', 'Paste your M3U playlist URL and click Play', 'Alternatively install a dedicated IPTV app like MyIPTV Player from Microsoft Store'] },
];
---

<Layout title={title} description={description} canonical="/setup/">
  <Header />
  <WhatsAppPopup />
  <WhatsPopup />

  <main class="relative min-h-screen pt-[80px] pb-16">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0A0E17] via-[#0D1321] to-[#0A0E17]" />
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(rgba(255,136,62,0.04) 1px, transparent 1px); background-size: 48px 48px;" />
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Hero -->
      <div class="text-center max-w-3xl mx-auto py-16 scroll-animate">
        <span class="inline-block px-4 py-1.5 rounded-full bg-[#169B62]/10 border border-[#169B62]/20 text-[12.5px] font-semibold text-[#169B62] uppercase tracking-wider mb-4">Setup</span>
        <h1 class="text-4xl sm:text-5xl font-black text-white mb-4 font-['Space_Grotesk']">Setup Guide</h1>
        <p class="text-[#8C96AA] text-lg">Get IPTV Ireland running on any device in minutes. Choose your device below.</p>
      </div>

      <!-- Devices -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {devices.map((device, i) => (
          <div class="scroll-animate glass-card rounded-2xl p-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-[#169B62]/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-[#169B62]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <div>
                <h2 class="text-2xl font-bold text-white">{device.name}</h2>
                <p class="text-[#8C96AA] text-sm">{device.brands}</p>
              </div>
            </div>

            <div class="space-y-4">
              {device.steps.map((step, stepIndex) => (
                <div class="flex items-start gap-4">
                  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-[#169B62]/20 flex items-center justify-center text-[#169B62] text-sm font-bold">{stepIndex + 1}</div>
                  <p class="text-[#8C96AA] leading-relaxed pt-1">{step}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Help CTA -->
      <div class="mt-16 scroll-animate text-center">
        <div class="glass-card rounded-2xl p-8" style="background: linear-gradient(135deg, rgba(22,155,98,0.12), rgba(255,136,62,0.08)); border: 1px solid rgba(22,155,98,0.3);">
          <h3 class="text-xl font-bold text-white mb-2">Still Stuck?</h3>
          <p class="text-[#8C96AA] mb-6">Our team can guide you through setup step by step via WhatsApp or Telegram.</p>
          <a 
            href="https://wa.link/9ezhx6"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-[#169B62] to-[#0E6B42] text-white font-bold rounded-xl transition-all duration-300 hover:from-[#1BD97A] hover:to-[#169B62] shadow-lg"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            Chat on WhatsApp
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
