---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppPopup from '../components/WhatsAppPopup.astro';
import WhatsPopup from '../components/WhatsPopup.astro';

const title = "IPTV Ireland | Best Premium IPTV Subscription in Ireland 2024";
const description = "Get the ultimate IPTV Ireland experience with 20,000+ channels, 4K streaming & Irish sports. Best IPTV subscription in Dublin, Cork, Belfast & all Ireland. Free trial available.";

const cities = ['Dublin', 'Belfast', 'Cork', 'Limerick', 'Waterford'];

const features = [
  { emoji: '11,000+', label: 'Worldwide Channels', desc: 'All Irish, UK & international channels — sport, news, entertainment and more from around the globe.' },
  { emoji: '50,000+', label: 'Updated Films & Series', desc: 'Our library of 50,000+ films and series is updated daily with the latest releases.' },
  { emoji: '', label: 'EPG Programme Guide', desc: 'Full electronic programme guide — see exactly what is on and when, on every channel.' },
  { emoji: '', label: 'Catchup Feature', desc: 'Missed a show? Watch up to 7 days back with our built-in catchup feature.' },
  { emoji: '', label: 'Lightning Fast Streams', desc: 'No buffering, no delays. Our servers guarantee a stable connection in HD and 4K.' },
  { emoji: '', label: '24/7 Customer Support', desc: 'Our support team is available around the clock via WhatsApp and Telegram.' },
];

const plans = [
  { 
    name: '1 Month', 
    price: '8', 
    period: 'total',
    monthly: '8,00/month',
    save: null,
    savePct: null,
    popular: false,
    features: ['All worldwide channels', 'Updated films & series', 'EPG guide included', 'Catchup feature', '24/7 support'],
    cta: 'Order Now',
    ctaClass: 'btn-outline',
    gradient: ''
  },
  { 
    name: '3 Months', 
    price: '20', 
    period: 'total',
    monthly: '6,67/month',
    savePct: '17%',
    popular: false,
    features: ['All worldwide channels', 'Updated films & series', 'EPG guide included', 'Catchup feature', '24/7 support'],
    cta: 'Order Now',
    ctaClass: 'btn-outline card-populair',
    gradient: ''
  },
  { 
    name: '6 Months', 
    price: '30', 
    period: 'total',
    monthly: '5,00/month',
    savePct: '37%',
    popular: false,
    features: ['All worldwide channels', 'Updated films & series', 'EPG guide included', 'Catchup feature', '24/7 support'],
    cta: 'Order Now',
    ctaClass: 'btn-outline',
    gradient: ''
  },
  { 
    name: '12 Months', 
    price: '55', 
    period: 'total',
    monthly: '4,58/month',
    savePct: '43%',
    popular: true,
    features: ['All worldwide channels', 'Updated films & series', 'EPG guide included', 'Catchup feature', 'VIP 24/7 support', '1 year player licence bonus'],
    cta: 'Order Now',
    ctaClass: 'btn-primary',
    gradient: 'style="background:linear-gradient(135deg,rgba(22,155,98,0.12),rgba(14,107,66,0.08));border:2px solid rgba(22,155,98,0.45)"'
  },
];

const reviews = [
  { name: 'Sean M.', location: 'Dublin', rating: 5, text: 'Absolutely brilliant service. All the sports channels I could want and the picture quality is unreal. Set up in minutes.' },
  { name: 'Aoife K.', location: 'Cork', rating: 5, text: 'Tried a few different providers but this is the only one that has not frozen during a match. The Irish channels are a game changer.' },
  { name: 'Michael R.', location: 'Belfast', rating: 5, text: 'Customer service is top tier. Had a small configuration issue and they sorted it within the hour. Highly recommend for anyone in Northern Ireland.' },
  { name: 'Lisa D.', location: 'Limerick', rating: 5, text: 'The annual plan is great value. Saved me a fortune compared to Sky. All the kids channels and box sets too.' },
  { name: 'Patrick T.', location: 'Waterford', rating: 4, text: 'Solid service. Works perfectly on my Firestick. Got the Premier League and all GAA action which was the main reason I signed up.' },
  { name: 'Niamh B.', location: 'Galway', rating: 5, text: 'As an Irish ex-pat this is the best way to stay connected with home channels. Never had a single issue buffering.' },
];

const reviewsDutchStyle = reviews.slice(0, 3);

const faqs = [
  { q: 'What is IPTV Ireland?', a: 'IPTV Ireland is a premium IPTV service with more than 10,000 live channels, films and series via the internet on any device.' },
  { q: 'On which devices does it work?', a: 'Smart TV (Samsung/LG), Android TV, Fire TV Stick, Apple TV, smartphone, tablet and PC/laptop.' },
  { q: 'How fast is my subscription activated?', a: 'Immediately after payment you receive the login details via WhatsApp — on average within 5 minutes.' },
  { q: 'What is the minimum internet speed?', a: 'At least 10 Mbps for HD, 25 Mbps for 4K. Most Irish connections easily exceed this.' },
  { q: 'Can I try IPTV Ireland for free?', a: 'Yes! Send a message via WhatsApp for a free 24-hour trial period.' },
  { q: 'Are there hidden costs?', a: 'No. The price you see is everything you pay. No installation fees, no hidden charges.' },
  { q: 'Which channels are available?', a: 'All Irish, UK, international and worldwide channels — sport, news, entertainment, kids and more.' },
  { q: 'What is the catchup feature?', a: 'With catchup you can watch missed broadcasts up to 7 days back — never miss an episode again.' },
  { q: 'What is the EPG guide?', a: 'The Electronic Programme Guide shows a complete TV guide with all programmes and times, just like a regular TV receiver.' },
  { q: 'How does the referral actie work?', a: 'Give your WhatsApp number with your order as referrer, or give the number of the person who referred you. You both receive 1 month free.' },
];

const whatsappOrder = "https://wa.link/9ezhx6";

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "IPTV Ireland Premium Subscription",
  "description": "Premium IPTV subscription service with 10,000+ channels, 4K quality, and Irish sports coverage across Dublin, Belfast, Cork, Limerick and Waterford.",
  "brand": {
    "@type": "Brand",
    "name": "IPTV Ireland"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "1247",
    "bestRating": "5"
  },
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": "8.00",
    "highPrice": "55.00",
    "priceCurrency": "EUR",
    "offerCount": "4",
    "availability": "https://schema.org/InStock"
  },
  "review": reviews.slice(0,3).map(r => ({
    "@type": "Review",
    "author": { "@type": "Person", "name": r.name },
    "reviewRating": { "@type": "Rating", "ratingValue": String(r.rating), "bestRating": "5" },
    "reviewBody": r.text
  }))
};
---

<Layout 
  title={title} 
  description={description}
  schema={schemaData}
>
  <Header />
  <WhatsAppPopup />
  <WhatsPopup />

  <!-- =========================================== -->
  <!-- HERO SECTION                                -->
  <!-- =========================================== -->
  <section id="section-hero" class="relative min-h-screen flex items-center pt-[72px] overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0A0E17] via-[#0D1321] to-[#0A0E17]"/>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#169B62]/8 rounded-full blur-[120px] -translate-y-1/4 translate-x-1/4"/>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[#FF883E]/6 rounded-full blur-[100px] translate-y-1/4 -translate-x-1/4"/>
      <div class="absolute inset-0" style="background-image: radial-gradient(rgba(255,136,62,0.04) 1px, transparent 1px); background-size: 48px 48px;"/>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-16 lg:py-0">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: Text -->
        <div class="animate-fade-up" style="animation-delay: 0.1s;">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass border mb-6 text-sm text-[#169B62] font-medium" style="background: rgba(22,155,98,0.12); border-color: rgba(22,155,98,0.3);">
            <span class="w-2 h-2 rounded-full bg-[#169B62] animate-pulse inline-block"/>Hundreds of happy customers trust IPTV Ireland
          </div>
          
          <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-black text-white leading-tight mb-6">
            The Best <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#169B62] to-[#FF883E]">IPTV</span> in Ireland
          </h1>
          
          <p class="text-lg sm:text-xl text-[#8C96AA] leading-relaxed mb-8 max-w-xl">
            Stream more than <strong class="text-white">10,000+ live channels</strong>, films and series in <strong class="text-white">Full HD and 4K</strong>. IPTV Ireland — the #1 best IPTV subscription.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 mb-10">
            <a 
              href={whatsappOrder}
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center gap-2.5 px-8 py-4 bg-gradient-to-r from-[#169B62] to-[#0E6B42] hover:from-[#1BD97A] hover:to-[#169B62] text-white text-[15px] font-bold rounded-xl transition-all duration-300 shadow-xl shadow-[#169B62]/25 hover:shadow-[#169B62]/40 hover:-translate-y-0.5"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              <span>Order Now</span>
            </a>
            <a 
              href="#section-bravo"
              class="inline-flex items-center justify-center gap-2 px-8 py-4 text-white/90 hover:text-white text-[15px] font-semibold rounded-xl border border-white/10 hover:bg-white/5 transition-all duration-300"
            >
              <span>View Features</span>
            </a>
          </div>
          
          <!-- Trust Stats -->
          <div class="flex flex-wrap items-center gap-6">
            <div class="flex -space-x-3">
              {[1,2,3,4,5].map(() => {
                const letters = ['S', 'A', 'M', 'L', 'J'];
                const letter = letters[Math.floor(Math.random() * letters.length)];
                return (
                  <div class="w-10 h-10 rounded-full border-2 border-[#0A0E17] bg-gradient-to-br from-[#169B62]/30 to-[#FF883E]/20 flex items-center justify-center">
                    <span class="text-xs font-bold text-white/60">{letter}</span>
                  </div>
                );
              })}
            </div>
            <div>
              <div class="flex items-center gap-1 mb-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-4 h-4 text-[#FF883E]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
                <span class="text-[13px] font-bold text-white ml-1.5">4.9/5</span>
              </div>
              <p class="text-[12.5px] text-[#8C96AA]">from 1,247 Irish customers</p>
            </div>
          </div>
        </div>

        <!-- Right: Visual -->
        <div class="hidden lg:flex items-center justify-center animate-fade-up" style="animation-delay: 0.3s;">
          <div class="relative w-full max-w-lg">
            <div class="absolute -inset-4 bg-gradient-to-r from-[#169B62]/20 to-[#FF883E]/20 rounded-3xl blur-2xl"/>
            <div class="relative glass-card rounded-2xl p-1 overflow-hidden">
              <div class="aspect-video bg-gradient-to-br from-[#0D1321] to-[#0A0E17] rounded-xl flex items-center justify-center relative overflow-hidden">
                <div class="absolute inset-0 opacity-20" style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,136,62,0.05) 2px, rgba(255,136,62,0.05) 4px);"/>
                <div class="text-center z-10 px-8">
                  <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[#169B62] to-[#0E6B42] flex items-center justify-center mx-auto mb-4 shadow-2xl shadow-[#169B62]/30">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <p class="text-white/80 font-semibold text-lg mb-1">10,000+ Channels</p>
                  <p class="text-[#8C96AA] text-sm">Irish &bull; UK &bull; International</p>
                </div>
              </div>
            </div>
            <!-- Floating badge -->
            <div class="absolute -bottom-4 -right-4 glass-card rounded-xl p-3" style="box-shadow: 0 0 24px rgba(255, 136, 62, 0.48);">
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-[#169B62]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                <span class="text-sm font-bold text-white">99.9% Uptime</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================== -->
  <!-- FEATURES GRID                               -->
  <!-- =========================================== -->
  <section id="section-bravo" class="relative py-20 sm:py-28">
    <div class="absolute inset-0 bg-[#0D1321]/50"/>
    <div class="absolute inset-0" style="background-image: radial-gradient(rgba(255,136,62,0.03) 1px, transparent 1px); background-size: 56px 56px;"/>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 scroll-animate">
        <span class="inline-block px-4 py-1.5 rounded-full bg-[#169B62]/10 border border-[#169B62]/20 text-[12.5px] font-semibold text-[#169B62] uppercase tracking-wider mb-4">Why Choose Us</span>
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-4 font-['Space_Grotesk']">Why IPTV Ireland?</h2>
        <p class="text-[#8C96AA] text-lg">Everything you need for the best IPTV experience in Ireland.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {features.map((f, i) => (
          <div 
            class="scroll-animate glass-card glass-card-hover rounded-2xl p-7 group"
            style={`transition-delay: ${i * 100}ms;`}
          >
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#169B62]/20 to-[#169B62]/5 border border-[#169B62]/20 flex items-center justify-center mb-5 group-hover:from-[#169B62]/30 group-hover:to-[#169B62]/10 transition-all duration-300">
              <svg class="w-6 h-6 text-[#169B62]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <h3 class="text-[16.5px] font-bold text-white mb-2.5 group-hover:text-[#169B62] transition-colors">{f.label}</h3>
            <p class="text-[13.5px] leading-relaxed text-[#8C96AA]">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- =========================================== -->
  <!-- LOCATION BADGES                             -->
  <!-- =========================================== -->
  <section class="relative py-12 border-y border-[rgba(255,136,62,0.06)] bg-[#0A0E17]/80">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h2 class="text-lg font-bold text-white mb-1 font-['Space_Grotesk']">Service Available Across Ireland</h2>
          <p class="text-[13.5px] text-[#8C96AA]">Optimized servers in Dublin & Belfast for the lowest latency.</p>
        </div>
        <div class="flex flex-wrap gap-2.5">
          {cities.map(city => (
            <a 
              href={`/locaties/${city.toLowerCase()}/`}
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white/5 hover:bg-[#169B62]/15 border border-white/5 hover:border-[#169B62]/30 text-[13.5px] font-medium text-[#8C96AA] hover:text-white transition-all duration-300"
            >
              <svg class="w-4 h-4 text-[#169B62]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM12 11a2 2 0 100-4 2 2 0 000 4z"/>
              </svg>
              {city}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================== -->
  <!-- PRICING TABLE (Matching Dutch IPTV)         -->
  <!-- =========================================== -->
  <section id="section-delta" class="relative py-20 sm:py-28">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0D1321] via-[#0A0E17] to-[#0D1321]"/>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 scroll-animate">
        <span class="inline-block px-4 py-1.5 rounded-full bg-[#FF883E]/10 border border-[#FF883E]/20 text-[12.5px] font-semibold text-[#FF883E] uppercase tracking-wider mb-4">Pricing</span>
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-4 font-['Space_Grotesk']">Choose Your IPTV Ireland Package</h2>
        <p class="text-[#8C96AA] text-lg">No hidden costs. No contract.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
        {plans.map((plan, i) => (
          <div 
            class={`scroll-animate relative rounded-2xl overflow-hidden ${plan.popular ? 'sm:col-span-2 xl:col-span-1' : ''}`}
            style={`transition-delay: ${i * 100}ms; ${plan.popular ? 'background:linear-gradient(135deg,rgba(22,155,98,0.12),rgba(14,107,66,0.08));border:2px solid rgba(22,155,98,0.45)' : ''}`}
          >
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="inline-block px-4 py-1 bg-gradient-to-r from-[#169B62] to-[#0E6B42] text-white text-[11px] font-bold uppercase tracking-wider rounded-full shadow-lg">Most Popular</span>
              </div>
            )}
            <div class={`p-6 flex flex-col h-full ${plan.popular ? 'pt-8' : 'glass-card'}`}>
              <div class={`text-sm font-medium mb-1 mt-2 ${plan.popular ? 'text-[#169B62]' : 'text-[#8C96AA]'}`}>{plan.popular ? 'Best Deal' : plan.name}</div>
              <h3 class="text-white font-bold text-xl mb-3">{plan.name}</h3>
              <div class="mb-1">
                <span class="text-4xl font-black text-white">&euro;{plan.price}</span>
                <span class="text-[#8C96AA] text-sm ml-1">{plan.period}</span>
              </div>
              <div class="text-[#8C96AA] text-xs mb-1">{plan.monthly}</div>
              {plan.savePct && <p class="text-[#169B62] text-xs font-semibold mb-4">Save {plan.savePct}</p>}
              {!plan.savePct && <div class="mb-4"></div>}
              <ul class="space-y-2 mb-8 flex-1">
                {plan.features.map(feature => (
                  <li class="flex items-start gap-2 text-sm text-[#8C96AA]">
                    <svg class="mt-0.5 flex-shrink-0 w-4 h-4" fill={plan.popular ? "#169B62" : "#22c55e"} viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a 
                href={whatsappOrder}
                target="_blank"
                rel="noopener noreferrer"
                class={`block w-full py-3 text-center rounded-xl text-sm font-bold transition-all duration-300 ${plan.popular ? 'bg-gradient-to-r from-[#169B62] to-[#0E6B42] text-white hover:from-[#1BD97A] hover:to-[#169B62] shadow-lg shadow-[#169B62]/20 hover:shadow-[#169B62]/40' : 'bg-white/5 hover:bg-white/10 text-white border border-white/10 hover:border-[#169B62]/30'}`}
              >
                {plan.cta}
              </a>
            </div>
          </div>
        ))}
      </div>
      
      <p class="text-center text-[#8C96AA] text-sm mt-8">Safe payment with iDEAL, credit card or PayPal. Instant activation after payment.</p>
    </div>
  </section>

  <!-- =========================================== -->
  <!-- REFERRAL SECTION                            -->
  <!-- =========================================== -->
  <section id="section-x" class="relative py-20 sm:py-28">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0A0E17] to-[#0D1321]"/>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 scroll-animate">
