---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppPopup from '../../components/WhatsAppPopup.astro';
import WhatsPopup from '../../components/WhatsPopup.astro';

const title = "IPTV Ireland Blog | Setup Guides, Tips & Troubleshooting";
const description = "Read the IPTV Ireland blog for setup guides, troubleshooting tips, and streaming advice. Fix buffering, install on your device and get the most out of your IPTV subscription.";

const posts = [
  {
    slug: 'fix-buffering-streams',
    title: 'How to Fix Buffering on IPTV Streams',
    excerpt: 'Buffering ruining your viewing experience? Learn the top 5 ways to eliminate buffering and enjoy smooth 4K playback on any device.',
    date: '2024-12-15',
    category: 'Troubleshooting',
  },
  {
    slug: 'install-lg-smart-tv',
    title: 'How to Install IPTV on Your LG Smart TV',
    excerpt: 'A step-by-step guide to installing IPTV on LG Smart TVs using the official app store and external players.',
    date: '2024-12-10',
    category: 'Setup Guide',
  },
  {
    slug: 'firestick-optimization',
    title: 'Firestick Performance Tips for IPTV',
    excerpt: 'Get the most out of your Amazon Fire TV Stick with these essential optimisation tips for streaming IPTV in 4K.',
    date: '2024-12-05',
    category: 'Setup Guide',
  },
  {
    slug: 'epg-guide-explained',
    title: 'What is an EPG Guide and Why You Need It',
    excerpt: 'Everything you need to know about the Electronic Programme Guide and how it transforms your IPTV experience.',
    date: '2024-11-28',
    category: 'Features',
  },
  {
    slug: 'catchup-vs-vod',
    title: 'Catchup vs VOD: What is the Difference?',
    excerpt: 'Confused about Catchup and VOD? We break down the key differences so you can make the most of your IPTV subscription.',
    date: '2024-11-20',
    category: 'Features',
  },
  {
    slug: 'internet-speed-requirements',
    title: 'Minimum Internet Speed for IPTV: The Complete Guide',
    excerpt: 'How fast does your internet need to be for HD and 4K IPTV streaming? We break down the exact speed requirements you need.',
    date: '2024-11-15',
    category: 'Troubleshooting',
  },
  {
    slug: 'smart-tv-vs-firestick',
    title: 'Smart TV vs Firestick: Which is Better for IPTV?',
    excerpt: 'Comparing built-in Smart TV apps vs dedicated Firestick devices for the best IPTV experience. Find out which option is right for you.',
    date: '2024-11-10',
    category: 'Setup Guide',
  },
  {
    slug: 'vpn-for-iptv',
    title: 'Why You Should Use a VPN with IPTV',
    excerpt: 'Learn how a VPN prevents ISP throttling and improves streaming stability for IPTV services in Ireland.',
    date: '2024-11-05',
    category: 'Troubleshooting',
  },
  {
    slug: 'recording-live-tv',
    title: 'How to Record Live TV with Your IPTV Subscription',
    excerpt: 'A complete guide to recording live TV using your IPTV app, third-party tools and device screen recording features.',
    date: '2024-10-28',
    category: 'Features',
  },
  {
    slug: 'optimising-wifi-streaming',
    title: 'Optimise Your WiFi for Buffer-Free IPTV Streaming',
    excerpt: 'Router placement, 5GHz vs 2.4GHz and network congestion tips for the smoothest IPTV streaming experience.',
    date: '2024-10-20',
    category: 'Troubleshooting',
  },
  {
    slug: 'parental-controls',
    title: 'Setting Up Parental Controls on IPTV',
    excerpt: 'Protect your family with parental controls. Learn how to block inappropriate channels and set PIN restrictions.',
    date: '2024-10-15',
    category: 'Features',
  },
];

const categories = ['All', 'Setup Guide', 'Troubleshooting', 'Features'];
---

<Layout title={title} description={description} canonical="/blog/">
  <Header />
  <WhatsAppPopup />
  <WhatsPopup />

  <main class="relative min-h-screen pt-[80px] pb-16">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0A0E17] via-[#0D1321] to-[#0A0E17]"/>
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(rgba(255,136,62,0.04) 1px, transparent 1px); background-size: 48px 48px;"/>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Hero -->
      <div class="py-16 text-center max-w-3xl mx-auto">
        <span class="inline-block px-4 py-1.5 rounded-full bg-[#169B62]/10 border border-[#169B62]/20 text-[12.5px] font-semibold text-[#169B62] uppercase tracking-wider mb-4">Blog</span>
        <h1 class="text-4xl sm:text-5xl font-black text-white mb-4">IPTV Ireland Blog</h1>
        <p class="text-[#8C96AA] text-lg">Setup guides, troubleshooting tips and streaming advice.</p>
      </div>

      <!-- Categories -->
      <div class="flex flex-wrap items-center justify-center gap-2 mb-12">
        {categories.map(cat => (
          <button class="px-5 py-2 rounded-xl text-sm font-medium bg-white/5 hover:bg-white/10 text-[#8C96AA] hover:text-white border border-white/5 hover:border-[#169B62]/30 transition-all duration-300">
            {cat}
          </button>
        ))}
      </div>

      <!-- Post Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {posts.map((post, i) => (
          <a 
            href={`/blog/${post.slug}/`}
            class="scroll-animate glass-card glass-card-hover rounded-2xl p-6 group block"
            style={`transition-delay: ${i * 100}ms;`}
          >
            <div class="flex items-center gap-2 mb-3">
              <span class="px-2.5 py-1 rounded-lg bg-[#169B62]/10 text-[#169B62] text-[11px] font-semibold uppercase tracking-wider">{post.category}</span>
              <span class="text-[#5F6B80] text-xs">{post.date}</span>
            </div>
            <h3 class="text-white font-bold text-lg mb-2 group-hover:text-[#169B62] transition-colors line-clamp-2">{post.title}</h3>
            <p class="text-[#8C96AA] text-sm leading-relaxed line-clamp-3">{post.excerpt}</p>
            <div class="mt-4 flex items-center gap-1 text-[#169B62] text-sm font-medium group-hover:gap-2 transition-all">
              <span>Read more</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>

      <!-- CTA Banner (always inject brand) -->
      <div class="mt-16 scroll-animate">
        <div class="glass-card rounded-2xl p-8 md:p-12 text-center" style="background: linear-gradient(135deg, rgba(22,155,98,0.12), rgba(255,136,62,0.08)); border: 1px solid rgba(22,155,98,0.3);">
          <h3 class="text-2xl font-bold text-white mb-2">Still Have Questions?</h3>
          <p class="text-[#8C96AA] mb-6">IPTV Ireland offers 24/7 support via WhatsApp. Get help with any issue in minutes.</p>
          <a 
            href="https://wa.link/9ezhx6"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-[#169B62] to-[#0E6B42] text-white font-bold rounded-xl transition-all duration-300 hover:from-[#1BD97A] hover:to-[#169B62] shadow-lg"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Chat on WhatsApp
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
