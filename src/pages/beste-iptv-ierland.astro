---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppPopup from '../components/WhatsAppPopup.astro';
import WhatsPopup from '../components/WhatsPopup.astro';

const title = "Top 3 Best IPTV Providers in Ireland (2024) | Independent Review";
const description = "Indepth review of the top 3 IPTV providers in Ireland. We compare features, pricing and reliability. Find out which service offers the best IPTV in Ireland for 2024.";

const providers = [
  {
    rank: '#1',
    name: 'IPTV Ireland',
    rating: '4.9/5',
    price: 'from €8/month',
    channels: '10,000+',
    desc: 'Hands down the best IPTV subscription in Ireland. IPTV Ireland offers everything Irish viewers need: all local channels, UK and international content, crystal clear 4K streams, and lightning fast activation. Their WhatsApp support responds in under 5 minutes, which is incredible. The referral programme gives you and a friend both 1 month free. If you want the best IPTV in Ireland, this is it.',
    pros: ['WhatsApp support under 5 minutes', 'All Irish channels included', '4K Ultra HD quality', 'Referral programme: 1 month free for both', 'Irish-based servers for low latency'],
    cons: ['No free trial longer than 24 hours'],
    cta: 'Get IPTV Ireland Now',
    featured: true,
  },
  {
    rank: '#2',
    name: 'Emerald Stream IPTV',
    rating: '4.2/5',
    price: 'from €12/month',
    channels: '8,500+',
    desc: 'Emerald Stream is a decent alternative if you are looking for a basic IPTV subscription. They offer a reasonable selection of UK and Irish channels, but the stream quality can be inconsistent during peak hours. Their support is email only and response times are slow. Good for casual viewers who do not need reliability.',
    pros: ['Basic Irish channels available', 'Works on most devices'],
    cons: ['Slow email-only support', 'Inconsistent stream quality', 'Higher price than competitors', 'No referral programme'],
    cta: 'View Emerald Stream',
    featured: false,
  },
  {
    rank: '#3',
    name: 'CelticView Pro',
    rating: '3.8/5',
    price: 'from €15/month',
    channels: '6,000+',
    desc: 'CelticView Pro is an entry-level IPTV provider with a limited channel selection. While they do offer some Irish channels, the stream quality is average at best and frequent buffering issues make it frustrating for live sports. Their pricing is also on the higher side for what you get.',
    pros: ['Simple setup process'],
    cons: ['Frequent buffering on live events', 'Limited Irish channel selection', 'Expensive for the quality', 'Slow customer support', 'No catchup feature'],
    cta: 'View CelticView',
    featured: false,
  },
];
---

<Layout 
  title={title} 
  description={description}
  canonical="/beste-iptv-ierland/"
  schema={{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Top 3 Best IPTV Providers in Ireland 2024",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Product",
          "name": "IPTV Ireland",
          "description": "Best IPTV subscription in Ireland with 10,000+ channels in 4K",
          "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "bestRating": "5", "reviewCount": "1247" },
          "offers": { "@type": "Offer", "price": "8.00", "priceCurrency": "EUR", "availability": "https://schema.org/InStock" }
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": { "@type": "Product", "name": "Emerald Stream IPTV", "description": "Basic IPTV with 8,500+ channels", "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.2", "bestRating": "5" } }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": { "@type": "Product", "name": "CelticView Pro", "description": "Entry-level IPTV with 6,000+ channels", "aggregateRating": { "@type": "AggregateRating", "ratingValue": "3.8", "bestRating": "5" } }
      }
    ]
  }}
>
  <Header />
  <WhatsAppPopup />
  <WhatsPopup />

  <main class="relative min-h-screen pt-[80px] pb-16">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0A0E17] via-[#0D1321] to-[#0A0E17]"/>
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(rgba(255,136,62,0.04) 1px, transparent 1px); background-size: 48px 48px;"/>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Hero -->
      <div class="text-center max-w-3xl mx-auto py-16 scroll-animate">
        <span class="inline-block px-4 py-1.5 rounded-full bg-[#169B62]/10 border border-[#169B62]/20 text-[12.5px] font-semibold text-[#169B62] uppercase tracking-wider mb-4">Indepth Review 2024</span>
        <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-black text-white leading-tight mb-6">
          Top 3 <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#169B62] to-[#FF883E]">Best IPTV</span> Providers in Ireland
        </h1>
        <p class="text-[#8C96AA] text-lg leading-relaxed mb-8 max-w-2xl mx-auto">
          We tested and reviewed dozens of IPTV providers so you do not have to. Here are the top 3 best IPTV subscriptions in Ireland, ranked by quality, price and customer satisfaction.
        </p>
      </div>

      <!-- Listicle -->
      <div class="max-w-4xl mx-auto space-y-8">
        {providers.map((provider, i) => (
          <article 
            class={`scroll-animate rounded-2xl overflow-hidden ${provider.featured ? 'relative' : 'glass-card'}`}
            style={`transition-delay: ${i * 150}ms; ${provider.featured ? 'background: linear-gradient(135deg, rgba(22,155,98,0.12), rgba(14,107,66,0.08)); border: 2px solid rgba(22,155,98,0.45);' : ''}`}
          >
            {provider.featured && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="inline-block px-4 py-1 bg-gradient-to-r from-[#169B62] to-[#0E6B42] text-white text-[11px] font-bold uppercase tracking-wider rounded-full shadow-lg">Top Recommendation</span>
              </div>
            )}
            <div class="p-8">
              <div class="flex items-start gap-4 mb-6">
                <div class={`text-3xl font-black ${provider.featured ? 'text-[#169B62]' : 'text-[#8C96AA]'}`}>{provider.rank}</div>
                <div class="flex-1">
                  <h2 class="text-2xl font-bold text-white mb-1">{provider.name}</h2>
                  <div class="flex items-center gap-3 flex-wrap">
                    <div class="flex items-center gap-1">
                      {[1,2,3,4,5].map((_, idx) => (
                        <svg class={`w-4 h-4 ${idx < Math.floor(parseFloat(provider.rating)) ? 'text-[#FF883E]' : 'text-[#5F6B80]'}`} fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                      ))}
                      <span class="text-white font-bold ml-1">{provider.rating}</span>
                    </div>
                    <span class="text-[#8C96AA] text-sm">• {provider.channels} channels</span>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-white font-bold text-lg">{provider.price}</p>
                </div>
              </div>
              
              <p class="text-[#8C96AA] leading-relaxed mb-6">{provider.desc}</p>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                  <h3 class="text-white font-semibold text-sm mb-3 flex items-center gap-2">
                    <span class="w-5 h-5 rounded-full bg-[#169B62]/20 flex items-center justify-center">
                      <svg class="w-3 h-3 text-[#169B62]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                    </span>
                    Pros
                  </h3>
                  <ul class="space-y-2">
                    {provider.pros.map(pro => (
                      <li class="flex items-start gap-2 text-sm text-[#8C96AA]">
                        <svg class="w-4 h-4 text-[#169B62] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        {pro}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h3 class="text-white font-semibold text-sm mb-3 flex items-center gap-2">
                    <span class="w-5 h-5 rounded-full bg-[#FF883E]/20 flex items-center justify-center">
                      <svg class="w-3 h-3 text-[#FF883E]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </span>
                    Cons
                  </h3>
                  <ul class="space-y-2">
                    {provider.cons.map(con => (
                      <li class="flex items-start gap-2 text-sm text-[#8C96AA]">
                        <svg class="w-4 h-4 text-[#FF883E] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                        {con}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
              
              <div class="flex flex-col sm:flex-row items-center gap-4">
                {provider.featured ? (
                  <a 
                    href="https://wa.link/9ezhx6"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-gradient-to-r from-[#169B62] to-[#0E6B42] hover:from-[#1BD97A] hover:to-[#169B62] text-white font-bold rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl"
                  >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                    </svg>
                    {provider.cta}
                  </a>
                ) : (
                  <span class="text-[#8C96AA] text-sm">No direct order link available — see provider website</span>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Disclaimer -->
      <div class="text-center mt-16 text-[#5F6B80] text-sm max-w-2xl mx-auto">
        <p>This review is independently conducted. IPTV Ireland is ranked as our top recommendation based on service quality, pricing and customer support. Individual results may vary.</p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
