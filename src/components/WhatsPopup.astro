            <span class="text-sm">Telegram</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  var chPopup = document.getElementById('ch-popup');
  var chCloseBtn = document.getElementById('ch-close');
  var chShown = sessionStorage.getItem('chPopup');
  
  if (!chShown) {
    setTimeout(function() {
      chPopup.classList.remove('hidden');
      chPopup.classList.add('animate-fade-up');
    }, 3000);
  }
  
  chCloseBtn.addEventListener('click', function() {
    chPopup.classList.add('hidden');
    sessionStorage.setItem('chPopup', '1');
  });
</script>