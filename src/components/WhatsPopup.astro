        </svg>
      </div>
      <div class="flex-1">
        <h3 class="text-white font-bold text-lg mb-1">Stay Updated</h3>
        <p class="text-[#8C96AA] text-sm mb-4">Join our channels for exclusive deals, new channels and promotions.</p>
        
        <div class="flex flex-col sm:flex-row gap-3">
          <a 
            href="https://whatsapp.com/channel/0029VayVaLpD8SE3bf8wMY3v"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 px-5 py-3 bg-[#25D366] hover:bg-[#22c55e] text-white font-semibold rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-[#25D366]/25 flex-1"
