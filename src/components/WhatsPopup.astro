---
const showAfterMs = 3000;
---

<div id="ch-popup" class="fixed bottom-0 left-0 right-0 z-[300] p-4 hidden" role="dialog" aria-label="Join our channels">
  <div class="max-w-lg mx-auto glass-card rounded-2xl p-6 relative border border-[#FF883E]/20" style="background: linear-gradient(135deg, rgba(10,14,23,0.95), rgba(13,19,33,0.95)); backdrop-filter: blur(20px);">
    <button 
      id="ch-close" 
      class="absolute top-3 right-3 w-8 h-8 rounded-lg bg-white/5 hover:bg-white/10 flex items-center justify-center text-[#5F6B80] hover:text-white transition-colors"
      aria-label="Close popup"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    
    <div class="flex items-start gap-4">
