---
interface Breadcrumb {
  label: string;
  href: string;
}

interface Props {
  items: Breadcrumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="py-4">
  <ol class="flex items-center flex-wrap gap-2 text-[13px]">
    <li class="flex items-center gap-2">
      <a 
        href="/" 
        class="text-[#8C96AA] hover:text-white transition-colors"
        itemprop="item"
      >
        <span itemprop="name">Home</span>
      </a>
      <meta itemprop="position" content="1" />
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-2" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <svg class="w-3 h-3 text-[#5F6B80]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <a
          href={item.href}
          class="text-[#8C96AA] hover:text-white transition-colors"
          itemprop="item"
        >
          <span itemprop="name" class={i === items.length - 1 ? 'text-white font-medium' : ''}>{item.label}</span>
        </a>
        <meta itemprop="position" content={String(i + 2)} />
      </li>
    ))}
  </ol>
</nav>