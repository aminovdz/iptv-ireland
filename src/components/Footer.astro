---
const footerLinks = {
  services: [
    { label: 'Home', href: '/' },
    { label: 'Setup Guide', href: '/setup/' },
    { label: 'Contact', href: '/contact/' },
    { label: 'Blog', href: '/blog/' },
  ],
  resources: [
    { label: 'Top Providers Review', href: '/beste-iptv-ierland/' },
    { label: 'Fix Buffering', href: '/blog/fix-buffering-streams/' },
    { label: 'Install on LG TV', href: '/blog/install-lg-smart-tv/' },
    { label: 'Firestick Tips', href: '/blog/firestick-optimization/' },
  ],
  legal: [
    { label: 'Privacy Policy', href: '/privacy/' },
    { label: 'Terms of Service', href: '/voorwaarden/' },
    { label: 'Refund Policy', href: '/voorwaarden/' },
  ],
};

const cities = ['Dublin', 'Belfast', 'Cork', 'Limerick', 'Waterford'];
---

<footer class="relative border-t border-[rgba(255,136,62,0.08)]" style="background: linear-gradient(180deg, #0D1321 0%, #060A12 100%);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 lg:gap-8 mb-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-5" aria-label="IPTV Ireland">
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-[#169B62] to-[#169B62]/70 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <span class="text-lg font-semibold text-white font-['Space_Grotesk']">IPTV Ireland</span>
        </a>
        <p class="text-[13.5px] leading-relaxed text-[#8C96AA] mb-6 max-w-sm">
          The most reliable streaming service across Ireland. Delivering premium entertainment directly to your screen since 2018.
        </p>
        <div class="flex items-center gap-3">
          <a href="#" aria-label="Facebook" class="w-10 h-10 rounded-lg bg-white/5 hover:bg-[#169B62]/20 border border-white/5 hover:border-[#169B62]/40 flex items-center justify-center text-[#8C96AA] hover:text-white transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" aria-label="Twitter" class="w-10 h-10 rounded-lg bg-white/5 hover:bg-[#169B62]/20 border border-white/5 hover:border-[#169B62]/40 flex items-center justify-center text-[#8C96AA] hover:text-white transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.836 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
          <a href="#" aria-label="Instagram" class="w-10 h-10 rounded-lg bg-white/5 hover:bg-[#169B62]/20 border border-white/5 hover:border-[#169B62]/40 flex items-center justify-center text-[#8C96AA] hover:text-white transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.85-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zM5.838 12a6.162 6.162 0 1112.324 0 6.162 6.162 0 01-12.324 0zM12 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM17.419 4.561a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-[13px] font-bold uppercase tracking-[0.1em] text-[#8C96AA] mb-4 font-['Space_Grotesk']">Navigation</h4>
        <ul class="space-y-2.5">
          {footerLinks.services.map(link => (
            <li>
              <a href={link.href} class="text-[13.5px] text-[#8C96AA] hover:text-white transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-[13px] font-bold uppercase tracking-[0.1em] text-[#8C96AA] mb-4 font-['Space_Grotesk']">Resources</h4>
        <ul class="space-y-2.5">
          {footerLinks.resources.map(link => (
            <li>
              <a href={link.href} class="text-[13.5px] text-[#8C96AA] hover:text-white transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-[13px] font-bold uppercase tracking-[0.1em] text-[#8C96AA] mb-4 font-['Space_Grotesk']">Legal</h4>
        <ul class="space-y-2.5">
          {footerLinks.legal.map(link => (
            <li>
              <a href={link.href} class="text-[13.5px] text-[#8C96AA] hover:text-white transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Cities -->
    <div class="border-t border-white/5 pt-8 mb-8">
      <h4 class="text-[13px] font-bold uppercase tracking-[0.1em] text-[#8C96AA] mb-3 font-['Space_Grotesk']">Coverage Areas</h4>
      <div class="flex flex-wrap gap-2">
        {cities.map(city => (
          <a 
            href={`/locaties/${city.toLowerCase()}/`} 
            class="px-4 py-2 text-[12.5px] font-medium bg-white/5 hover:bg-[#169B62]/15 text-[#8C96AA] hover:text-white rounded-lg border border-white/5 hover:border-[#169B62]/30 transition-all duration-300"
          >
            {city}, Ireland
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-[12.5px] text-[#5F6B80]">
        &copy; {new Date().getFullYear()} IPTV Ireland. All rights reserved. A subsidiary of Digital Stream Solutions Ltd.
      </p>
      <p class="text-[12.5px] text-[#5F6B80]">
        Made with care for the Emerald Isle
      </p>
    </div>
  </div>
</footer>