---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
}

const { 
  title, 
  description, 
  image = '/images/og-default.svg', 
  canonical = '' 
} = Astro.props;

const canonicalUrl = canonical || Astro.url.pathname;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
<meta name="theme-color" content="#1B75BB" />
<meta name="msapplication-TileColor" content="#1B75BB" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="format-detection" content="telephone=no" />
<meta name="referrer" content="origin-when-cross-origin" />
<meta name="keywords" content="iptv ireland, iptv subscription, best iptv ireland, dublin iptv, belfast iptv, cork iptv, irish sports streaming, 4k iptv" />
<meta name="author" content="IPTV Ireland" />
<meta name="geo.region" content="IE" />
<meta name="geo.placename" content="Ireland" />
<meta name="ICBM" content="53.41291,-8.24389" />
<meta name="geo.position" content="53.41291;-8.24389" />
<link rel="alternate" hreflang="en-ie" href={`https://iptv-ireland.co${canonicalUrl}`} />
<link rel="alternate" hreflang="x-default" href={`https://iptv-ireland.co${canonicalUrl}`} />
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" as="style" />
<link rel="dns-prefetch" href="https://cdn.tailwindcss.com" />

<title>{title}</title>
<meta name="description" content={description} />

<link rel="canonical" href={`https://iptv-ireland.co${canonicalUrl}`} />

<meta property="og:site_name" content="IPTV Ireland" />
<meta property="og:type" content="website" />
<meta property="og:url" content={`https://iptv-ireland.co${canonicalUrl}`} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`https://iptv-ireland.co${image}`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_IE" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`https://iptv-ireland.co${image}`} />

<link rel="icon" type="image/svg+xml" href="/images/brand-icon-1.svg" />
<link rel="apple-touch-icon" href="/images/brand-icon-1.svg" />
<link rel="preload" as="image" href="/images/hero-display.svg" type="image/svg+xml" />
<link rel="preload" as="image" href="/images/og-default.svg" type="image/svg+xml" />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "IPTV Ireland",
  "url": "https://iptv-ireland.co",
  "logo": "https://iptv-ireland.co/images/brand-icon-1.svg",
  "sameAs": [
    "https://www.facebook.com/iptv-irish",
    "https://twitter.com/iptv-irish",
    "https://www.instagram.com/iptv-irish"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer support",
    "telephone": "+353-123-456-789",
    "availableLanguage": "English"
  }
})} />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "url": "https://iptv-ireland.co",
  "name": "IPTV Ireland",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://iptv-ireland.co/?s={search_term_string}",
    "query-input": "required name=search_term_string"
  }
})} />